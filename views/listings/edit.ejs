<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RighChoice</title>
</head>
<body>
    <h3>Edit New Listing</h3>
    <form method="POST" action="/listings/<%= listing._id %>?_method=PUT">
        <input name = "listing[title]" value="<%= listing.title %>" type = "text"/>
        <br>
        <br>
        <input name = "listing[description]" value="<%= listing.description %>" type = "textarea"/>
        <br>
        <br>
        <input name = "listing[image]" value="<%= listing.image %>" placeholder="enter image url" type = "text"/>  
        <br>
        <input name = "listing[price]" value="<%= listing.price %>"  placeholder="enter price" type = "number"/>
        <br>
        <input name = "listing[location]" value="<%= listing.location %>" placeholder="enter location" type = "text"/>
        <br>
        <input name = "listing[country]" value="<%= listing.country %>" placeholder="enter country" type = "text"/>
        <br>
        <button>Edit Listing</button>
    </form>
</body>
</html>